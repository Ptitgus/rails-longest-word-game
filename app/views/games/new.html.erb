<h1 class="display-1 ms-5">New Game</h1>
<nav>
  <ul class="horizontal-list ms-3">
    <li><%= @letters[0] %></li>
    <li><%= @letters[1] %></li>
    <li><%= @letters[2] %></li>
    <li><%= @letters[3] %></li>
    <li><%= @letters[4] %></li>
    <li><%= @letters[5] %></li>
    <li><%= @letters[6] %></li>
    <li><%= @letters[7] %></li>
    <li><%= @letters[8] %></li>
    <li><%= @letters[9] %></li>
  </ul>
</nav>

<p class="ms-5">What is the longest word you can find ?</p>
  <form action="score" method="post" data-turbo="false">
    <div class="d-flex w-25 ms-5">
    <input class="form-control" type="text" id="word" name="word">
    <input type="submit" class="btn btn-primary" value="Play">
    <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
    <%= hidden_field_tag :letters, @letters %>
    </div>
  </form>
